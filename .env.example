# ─────────────────────────────────────────────────────────────
# Telos AI — environment variables
# Copy to .env.local for local dev, and set the same in Vercel
# (Project → Settings → Environment Variables) for production.
# ─────────────────────────────────────────────────────────────

# ── Supabase ──
# Used by the waitlist signup (server-side insert with the service role).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SERVER-ONLY. Never expose this to the client. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=

# ── Resend ──
# RESEND_API_KEY powers BOTH the transactional confirmation email and the
# marketing contact store, but they are separate Resend products with separate
# billing (transactional = "Emails", marketing = "Contacts/Segments").
RESEND_API_KEY=
# Where 'signup could not be saved' alerts go for manual recovery.
# Defaults to william.gouldsmith@telosai.co.uk if unset.
WAITLIST_ALERT_EMAIL=

# OPTIONAL. Resend now uses global Contacts (no list needed) — signups are
# stored automatically with just RESEND_API_KEY. If you also want them tagged
# into a Segment, create one in the Resend dashboard (Contacts -> Segments)
# and paste its ID here. Leave empty to skip segment tagging.
RESEND_WAITLIST_SEGMENT_ID=

# ── Site ──
NEXT_PUBLIC_SITE_URL=https://telosai.co.uk
