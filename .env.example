# ─────────────────────────────────────────────────────────────
# Telos AI — environment variables
# Copy to .env.local for local dev, and set the same in Vercel
# (Project → Settings → Environment Variables) for production.
# ─────────────────────────────────────────────────────────────

# ── Supabase ──
# Used by the waitlist signup (server-side insert with the service role).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SERVER-ONLY. Never expose this to the client. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=

# ── Resend ──
# RESEND_API_KEY powers BOTH the transactional confirmation email and the
# marketing audience add, but they are separate Resend products with separate
# billing (transactional = "Emails", marketing = "Audiences/Contacts").
RESEND_API_KEY=
# The Resend Audience the waitlist contacts get added to.
# Create an audience in the Resend dashboard and paste its ID here.
RESEND_WAITLIST_AUDIENCE_ID=

# ── Site ──
NEXT_PUBLIC_SITE_URL=https://telosai.co.uk
