# ─────────────────────────────────────────────────────────────
# Telos AI — environment variables
# Copy to .env.local for local dev, and set the same in Vercel
# (Project → Settings → Environment Variables) for production.
# ─────────────────────────────────────────────────────────────

# ── Supabase ──
# Used by the portal, admin dashboard, and the server-side (service-role) actions.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SERVER-ONLY. Never expose this to the client. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=

# ── Resend ──
# Powers transactional email: contact-form enquiries, invoice/quote
# reminders, and the weekly/monthly report crons.
RESEND_API_KEY=

# ── Expert agents / LLM provider ──
# The /agents experts run through one provider, switchable with a single
# variable. Add the matching key and the agents use it with no code change.
#
#   LLM_PROVIDER=gemini      (default)  Google Gemini — free tier available
#   LLM_PROVIDER=groq                   Groq (Llama)  — free tier available
#   LLM_PROVIDER=anthropic              Claude        — needs ANTHROPIC credit
LLM_PROVIDER=gemini

# Provider API keys — set the ONE that matches LLM_PROVIDER (others can stay
# empty). Get a free Gemini key at aistudio.google.com, a free Groq key at
# console.groq.com.
GEMINI_API_KEY=
GROQ_API_KEY=
# Powers the anthropic provider AND the site widgets (receptionist, booking,
# social, cron summaries), which still call Claude directly. Needs credit.
ANTHROPIC_API_KEY=

# OPTIONAL model overrides per provider (sensible defaults are built in):
#   GEMINI_MODEL  defaults to gemini-2.5-flash
#   GROQ_MODEL    defaults to llama-3.3-70b-versatile
#   EXPERTS_MODEL defaults to claude-sonnet-5 (anthropic only)
GEMINI_MODEL=
GROQ_MODEL=
EXPERTS_MODEL=

# ── Site ──
NEXT_PUBLIC_SITE_URL=https://telosai.co.uk
